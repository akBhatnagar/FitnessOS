# Production backend env — copy to .env.production on the server.
# Do not commit .env.production.

APP_ENV=production
APP_NAME=FitnessOS
APP_VERSION=1.0.0
DEBUG=false
SECRET_KEY=generate-a-long-random-string
ALLOWED_ORIGINS=https://your-domain.example

DATABASE_URL=postgresql+asyncpg://fitnessos:password@localhost:5435/fitnessos
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=5
DATABASE_ECHO=false

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_STORAGE_BUCKET=fitnessos-media

CLERK_SECRET_KEY=sk_live_your_clerk_secret_key
CLERK_PUBLISHABLE_KEY=pk_live_your_clerk_publishable_key
CLERK_JWT_ISSUER=https://your-clerk-domain.clerk.accounts.dev

DEFAULT_LLM_PROVIDER=openai
DEFAULT_EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_DEFAULT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

REDIS_URL=redis://localhost:6380/0
CELERY_BROKER_URL=redis://localhost:6380/0
CELERY_RESULT_BACKEND=redis://localhost:6380/1

EMBEDDING_DIMENSIONS=1536
MEMORY_RETRIEVAL_TOP_K=10
MEMORY_SIMILARITY_THRESHOLD=0.75

RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_CHAT_PER_MINUTE=20

LOG_LEVEL=INFO
LOG_FORMAT=json
