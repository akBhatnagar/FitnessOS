async def seed_exercises() -> None:
    async with AsyncSession(engine) as session:
        async with session.begin():
            count = await session.execute(text("SELECT COUNT(*) FROM exercises"))
            existing = count.scalar_one()
            if existing > 0:
                print(f"Exercises already seeded ({existing} exercises). Skipping.")
                return

            inserted = 0
            for row in EXERCISES:
                (name, slug, ex_type, primary, secondary, equipment, is_compound,
                 met, tags, instructions, tips) = row

                await session.execute(text("""
                    INSERT INTO exercises (
                        id, name, slug, exercise_type, primary_muscle, secondary_muscles,
                        equipment_needed, is_compound, met_value, tags,
                        instructions, tips, created_at, updated_at
                    ) VALUES (
                        :id, :name, :slug, :type, :primary, :secondary,
                        :equipment, :compound, :met, :tags,
                        :instructions, :tips, NOW(), NOW()
                    )
                """), {
                    "id": str(uuid4()),
                    "name": name,
                    "slug": slug,
                    "type": ex_type,
                    "primary": primary,
                    "secondary": secondary,
                    "equipment": equipment,
                    "compound": is_compound,
                    "met": met,
                    "tags": tags,
                    "instructions": instructions,
                    "tips": tips,
                })
                inserted += 1

        print(f"✅  Seeded {inserted} exercises")
        print(f"   Push: chest, shoulders, triceps")
        print(f"   Pull: back, biceps")
        print(f"   Legs + Core + Swimming")


if __name__ == "__main__":
    asyncio.run(seed_exercises())
