async def seed_foods() -> None:
    async with AsyncSession(engine) as session:
        async with session.begin():
            count_result = await session.execute(
                text("SELECT COUNT(*) FROM food_database")
            )
            existing = count_result.scalar_one()
            if existing > 0:
                print(f"Food database already has {existing} entries. Skipping.")
                return

            inserted = 0
            for row in FOODS:
                (name, cals, protein, carbs, fat, fiber, sugar,
                 serving_g, serving_desc, tags, is_veg, is_vegan) = row

                await session.execute(text("""
                    INSERT INTO food_database (
                        id, name, calories_per_100g, protein_g, carbs_g, fat_g,
                        fiber_g, sugar_g, serving_size_g, serving_description,
                        tags, is_vegetarian, is_vegan, is_gluten_free, is_user_created,
                        created_at, updated_at
                    ) VALUES (
                        :id, :name, :cals, :protein, :carbs, :fat,
                        :fiber, :sugar, :serving_g, :serving_desc,
                        :tags, :is_veg, :is_vegan, false, false,
                        NOW(), NOW()
                    )
                """), {
                    "id": str(uuid4()),
                    "name": name,
                    "cals": cals,
                    "protein": protein,
                    "carbs": carbs,
                    "fat": fat,
                    "fiber": fiber,
                    "sugar": sugar,
                    "serving_g": serving_g,
                    "serving_desc": serving_desc,
                    "tags": tags,
                    "is_veg": is_veg,
                    "is_vegan": is_vegan,
                })
                inserted += 1

        print(f"✅  Seeded {inserted} Indian vegetarian foods into food_database")
        print(f"   Categories: dairy, legumes, grains, veg, fruits, nuts, meals")
        print(f"   All macros per 100g (standard nutritional format)")


if __name__ == "__main__":
    asyncio.run(seed_foods())
