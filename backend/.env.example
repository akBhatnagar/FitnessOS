# ============================================================
# FitnessOS Backend — Environment Variables
# Copy to .env and fill in your values. Never commit .env.
# ============================================================

# ---- Application ----
APP_ENV=development
APP_NAME=FitnessOS
APP_VERSION=1.0.0
DEBUG=true
SECRET_KEY=your-secret-key-min-32-chars-change-in-production
ALLOWED_ORIGINS=http://localhost:3000,https://your-production-domain.com

# ---- Database ----
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/fitnessos
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_ECHO=false

# ---- Supabase ----
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_STORAGE_BUCKET=fitnessos-media

# ---- Clerk Authentication ----
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
CLERK_JWT_ISSUER=https://your-clerk-domain.clerk.accounts.dev

# ---- LLM Providers ----
# Set the provider you want to use as the default
DEFAULT_LLM_PROVIDER=openai
DEFAULT_EMBEDDING_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_DEFAULT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
ANTHROPIC_DEFAULT_MODEL=claude-3-5-sonnet-20241022

# Google
GOOGLE_API_KEY=your-google-api-key
GOOGLE_DEFAULT_MODEL=gemini-1.5-pro

# OpenRouter (access multiple models via one API)
OPENROUTER_API_KEY=sk-or-your-openrouter-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Ollama (local models)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.1

# ---- Redis / Celery ----
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ---- Memory & Embeddings ----
EMBEDDING_DIMENSIONS=1536
MEMORY_RETRIEVAL_TOP_K=10
MEMORY_SIMILARITY_THRESHOLD=0.75

# ---- Rate Limiting ----
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_CHAT_PER_MINUTE=20

# ---- Logging ----
LOG_LEVEL=INFO
LOG_FORMAT=json
